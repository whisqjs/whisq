{
  "name": "@whisq/router",
  "version": "0.1.0-alpha.10",
  "description": "Signal-based router for Whisq applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "size": "size-limit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 KB",
      "gzip": true
    }
  ],
  "keywords": [
    "router",
    "whisq",
    "signals",
    "pushstate"
  ],
  "author": "Markot s. r. o.",
  "license": "MIT",
  "dependencies": {
    "@whisq/core": "workspace:*"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.2.0",
    "jsdom": "^29.0.2",
    "size-limit": "^11.2.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whisqjs/whisq.git",
    "directory": "packages/router"
  },
  "homepage": "https://whisq.dev",
  "sideEffects": false
}
