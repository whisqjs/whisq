{
  "name": "@whisq/testing",
  "version": "0.1.0-alpha.4",
  "description": "Testing utilities for Whisq components — render, screen queries, fireEvent",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "whisq",
    "testing",
    "vitest",
    "component-testing"
  ],
  "author": "Markot s. r. o.",
  "license": "MIT",
  "dependencies": {
    "@whisq/core": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whisqjs/whisq.git",
    "directory": "packages/testing"
  },
  "homepage": "https://whisq.dev",
  "sideEffects": false
}
