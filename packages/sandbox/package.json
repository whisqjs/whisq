{
  "name": "@whisq/sandbox",
  "version": "0.1.0-alpha.4",
  "description": "Sandboxed code execution for Whisq — isolated environment with configurable limits",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "whisq",
    "sandbox",
    "wasm",
    "isolation"
  ],
  "author": "Markot s. r. o.",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whisqjs/whisq.git",
    "directory": "packages/sandbox"
  },
  "homepage": "https://whisq.dev",
  "sideEffects": false
}
