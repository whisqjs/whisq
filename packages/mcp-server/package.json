{
  "name": "@whisq/mcp-server",
  "version": "0.1.0-alpha.1",
  "description": "MCP server for Whisq — AI tool integrations for component scaffolding and code validation",
  "type": "module",
  "bin": {
    "whisq-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "whisq",
    "mcp",
    "ai",
    "model-context-protocol"
  ],
  "author": "Markot s. r. o.",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whisqjs/whisq.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://whisq.dev",
  "sideEffects": false
}
