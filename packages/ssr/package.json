{
  "name": "@whisq/ssr",
  "version": "0.1.0-alpha.1",
  "description": "Server-side rendering for Whisq applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run --passWithNoTests",
    "size": "size-limit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "3 KB",
      "gzip": true
    }
  ],
  "keywords": [
    "whisq",
    "ssr",
    "server-side-rendering"
  ],
  "author": "Markot s. r. o.",
  "license": "MIT",
  "dependencies": {
    "@whisq/core": "workspace:*"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.0.0",
    "jsdom": "^29.0.2",
    "size-limit": "^11.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/whisqjs/whisq.git",
    "directory": "packages/ssr"
  },
  "homepage": "https://whisq.dev",
  "sideEffects": false
}
